{
  "JobFeeds": {
    "MaxItemsPerFeed": 20,
    "Sources": [
      {
        "Name": "Remote OK",
        "Url": "https://remoteok.com/remote-dev-jobs.rss"
      },
      {
        "Name": "We Work Remotely",
        "Url": "https://weworkremotely.com/categories/remote-programming-jobs.rss"
      },
      {
        "Name": "HN Jobs",
        "Url": "https://hnrss.org/jobs?count=20"
      },
      {
        "Name": "Indeed (Bing RSS)",
        "Url": "https://www.bing.com/search?format=rss&q=site%3Aindeed.com%2Fviewjob%20software%20engineer%20remote"
      },
      {
        "Name": "Greenhouse (Bing RSS)",
        "Url": "https://www.bing.com/search?format=rss&q=site%3Aboards.greenhouse.io%20software%20engineer"
      },
      {
        "Name": "Python.org Jobs",
        "Url": "https://www.python.org/jobs/feed/rss/"
      },
      {
        "Name": "Django Jobs",
        "Url": "https://www.djangoproject.com/rss/community/jobs/"
      },
      {
        "Name": "Jobicy",
        "Url": "https://jobicy.com/?feed=job_feed"
      },
      {
        "Name": "Smashing Magazine Jobs",
        "Url": "https://www.smashingmagazine.com/jobs/feed/"
      },
      {
        "Name": "Reddit RemoteJS",
        "Url": "https://www.reddit.com/r/remotejs/.rss"
      }
    ]
  },
  "ResumeUpload": {
    "MaxFileSizeInMegabytes": 5,
    "AllowedExtensions": [
      ".pdf",
      ".docx"
    ]
  },
  "Ai": {
    "Enabled": false,
    "Endpoint": "https://api.openai.com/v1/chat/completions",
    "Model": "gpt-5-mini",
    "ApiKey": "xpto",
    "ApiKeyHeaderName": "Authorization",
    "MaxJobsPerRequest": 8,
    "Temperature": 0.2,
    "RequestTimeoutSeconds": 45,
    "AllowHeuristicFallback": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
